# Database (auto-configured in Docker Compose; set for local development)
DATABASE_URL=postgresql://clawbolt:clawbolt@localhost:5432/clawbolt

# CORS — comma-separated list of allowed origins (no wildcard with credentials)
# Default: http://localhost:3000,http://localhost:8000 (local dev only)
# Production: set to your actual frontend origin(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=15

# Premium plugin (leave empty for OSS mode)
PREMIUM_PLUGIN=

# Messaging
MESSAGING_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated list of allowed Telegram chat IDs (empty = allow all)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Comma-separated list of allowed Telegram usernames (empty = allow all)
# If both are set, a message is allowed if EITHER matches.
# TELEGRAM_ALLOWED_USERNAMES=alice,bob

# E2E testing: Telegram chat_id to send test messages to
TELEGRAM_TEST_CHAT_ID=

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_API_BASE=              # Custom API base URL (e.g. http://localhost:1234/v1 for LM Studio)
VISION_MODEL=gpt-4o

# LLM Provider API Keys — set the ones you want to use.
# The any-llm SDK reads these from the environment automatically.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=

# Any LLM Managed Platform (optional) — set this to use the any-llm.ai key vault
# instead of individual provider keys above. See https://any-llm.ai
# ANY_LLM_KEY=

# Storage — "local" (default, no setup needed), "dropbox", or "google_drive"
# Local storage saves files to data/storage/ on disk.
# See README.md "File Storage Setup" for Dropbox/Google Drive configuration.
STORAGE_PROVIDER=local
DROPBOX_ACCESS_TOKEN=
GOOGLE_DRIVE_CREDENTIALS_JSON=

# Whisper
WHISPER_MODEL_SIZE=base

# Heartbeat (proactive check-ins)
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_MINUTES=30
HEARTBEAT_MAX_DAILY_MESSAGES=5
HEARTBEAT_QUIET_HOURS_START=20
HEARTBEAT_QUIET_HOURS_END=7
