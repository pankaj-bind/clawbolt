# Database (auto-configured in Docker Compose; set for local development)
DATABASE_URL=postgresql://backshop:backshop@localhost:5432/backshop

# CORS
CORS_ORIGINS=*

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=15

# Premium plugin (leave empty for OSS mode)
PREMIUM_PLUGIN=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# E2E testing: verified phone number that Twilio trial can send to
TWILIO_TEST_TO_NUMBER=

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
VISION_MODEL=gpt-4o

# LLM Provider API Keys — set the ones you want to use.
# The any-llm SDK reads these from the environment automatically.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=

# Any LLM Managed Platform (optional) — set this to use the any-llm.ai key vault
# instead of individual provider keys above. See https://any-llm.ai
# ANY_LLM_KEY=

# Storage ("dropbox" or "google_drive")
STORAGE_PROVIDER=dropbox
DROPBOX_ACCESS_TOKEN=
GOOGLE_DRIVE_CREDENTIALS_JSON=

# Whisper
WHISPER_MODEL_SIZE=base
